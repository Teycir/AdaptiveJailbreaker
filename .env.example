# Copy this file to .env and fill in your values
# .env is gitignored — never commit real secrets

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
D1_DATABASE_ID=your_d1_database_id
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key

# Set after first `wrangler deploy` — grab the URL from the deploy output
API_WORKER_URL=https://ajar-api.<your-subdomain>.workers.dev
NEXT_PUBLIC_API_URL=https://ajar-api.<your-subdomain>.workers.dev

# Auto-generated by setup-secrets.sh
API_INTERNAL_SECRET=your_generated_secret
