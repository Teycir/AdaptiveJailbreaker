# ── Cloudflare deployment ────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
D1_DATABASE_ID=

# ── Gemini key pool (comma-separated) ───────────────────────────────────────
# Set as a wrangler secret: wrangler secret put GEMINI_API_KEYS
# Multiple keys rotate automatically on rate-limit.
# Free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEYS=AIza...,AIza...

# ── Worker URL (fill after first deploy) ────────────────────────────────────
API_WORKER_URL=https://ajar-api.<your-account>.workers.dev
NEXT_PUBLIC_API_URL=https://ajar-api.<your-account>.workers.dev
